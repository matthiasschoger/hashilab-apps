
plugin_id   = "nfs"
type        = "csi"
id          = "paperless-postgres"
name        = "Paperless Postgres"

capability {
	access_mode = "single-node-writer"
	attachment_mode = "file-system"
}

context {
  server = "storage.home"
  share = "/volume2/homelab"
  subDir = "paperless/postgres"
  mountPermissions = "0"
}

mount_options {
  fs_type = "nfs"
  mount_flags = [ "hard", "sync" ]
}

