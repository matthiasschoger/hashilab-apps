
plugin_id   = "nfs"
type        = "csi"
id          = "mealie"
name        = "Mealie"

capability {
	access_mode = "single-node-writer"
	attachment_mode = "file-system"
}

context {
  server = "storage.home"
  share = "/volume2/homelab"
  subDir = "mealie"
}

mount_options {
  fs_type = "nfs"
  mount_flags = [ "soft", "async" ]
}

